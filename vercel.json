{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.py": {
      "maxDuration": 60,
      "excludeFiles": "{.venv/**,**/__pycache__/**,tests/**,__tests__/**,docs/**,.github/**,scripts/**}"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py?path=/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/api/index.py?path=/:path*"
    }
  ]
}
