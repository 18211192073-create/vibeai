{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "/api/index.py?path=/api/:path*"
    },
    {
      "source": "/:path*",
      "destination": "/api/index.py?path=/:path*"
    }
  ]
}
